  "keyFeatures": [
    "Hybrid search combining BM25 full-text, vector semantic search, and LLM reranking",
    "Local on-device execution using GGUF models via node-llama-cpp",
    "Smart chunking with markdown-aware boundary detection",
    "Context management for hierarchical metadata",
    "Document ID (docid) system for quick reference",
    "MCP server for AI agent integration",
    "Query document format with typed sub-queries (lex, vec, hyde)",
    "Multiple output formats (JSON, CSV, MD, XML)",
    "Collection management with include/exclude filtering"
  ],
